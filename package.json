{
  "name": "terminfo.dev-root",
  "private": true,
  "license": "CC-BY-4.0",
  "workspaces": [
    "packages/*"
  ],
  "type": "module",
  "scripts": {
    "terminfo": "bun packages/terminfo.dev/src/index.tsx",
    "admin": "bun packages/admin/src/index.ts",
    "probe": "bun packages/admin/src/index.ts probe",
    "probe:termless": "bun packages/admin/src/index.ts probe termless --all",
    "probe:apps": "bun packages/admin/src/index.ts probe app --all",
    "probe:server": "bun packages/admin/src/index.ts probe server --all",
    "probe:mux": "bun packages/admin/src/index.ts probe mux --all",
    "analysis": "bun scripts/generate-analysis.ts",
    "analysis:validate": "bun scripts/generate-analysis.ts --validate",
    "dev": "vitepress dev docs",
    "build": "bunx --bun vitepress build docs",
    "preview": "vitepress preview docs",
    "validate": "bun scripts/validate.ts",
    "check-404s": "bun scripts/check-404s.ts",
    "sitefile": "bun scripts/sitefile.ts",
    "explore": "bun scripts/explore.ts",
    "radar": "bun scripts/radar.ts",
    "candidates": "bun scripts/candidates.ts",
    "update": "bun scripts/update.ts",
    "sync-probe-status": "bun scripts/sync-probe-status.ts",
    "watch-releases": "bun scripts/watch-releases.ts",
    "fmt": "oxfmt --write .",
    "fmt:check": "oxfmt --check .",
    "fix": "oxfmt --write ."
  },
  "dependencies": {
    "@silvery/ansi": "^0.19.0",
    "@silvery/commander": "^0.19.0",
    "@termless/core": "^0.6.0",
    "commander": "^14.0.3",
    "loggily": "^0.8.0",
    "silvery": "^0.19.0"
  },
  "devDependencies": {
    "@terminfo/admin": "workspace:*",
    "@terminfo/probe-defs": "workspace:*",
    "@terminfo/probes": "workspace:*",
    "@vue/server-renderer": "^3.5.31",
    "oxfmt": "^0.38.0",
    "terminfo.dev": "workspace:*",
    "vitepress": "^1.6.4",
    "vitepress-enrich": "^0.4.0",
    "vitest": "^4.1.4",
    "vue": "^3.5.31"
  },
  "engines": {
    "node": ">=23.6.0"
  }
}
