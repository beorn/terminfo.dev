{
  "name": "terminfo.dev",
  "private": true,
  "type": "module",
  "scripts": {
    "terminfo": "bun packages/cli/src/index.ts",
    "probe": "bun packages/cli/src/index.ts probe",
    "probe:termless": "bun packages/cli/src/index.ts probe termless --all",
    "probe:apps": "bun packages/cli/src/index.ts probe app --all",
    "probe:server": "bun packages/cli/src/index.ts probe server --all",
    "analysis": "bun scripts/generate-analysis.ts",
    "analysis:validate": "bun scripts/generate-analysis.ts --validate",
    "dev": "vitepress dev docs",
    "build": "vitepress build docs",
    "preview": "vitepress preview docs"
  },
  "dependencies": {
    "@termless/core": "^0.4.0",
    "commander": "^13.1.0",
    "loggily": "^0.4.0",
    "silvery": "^0.4.1"
  },
  "devDependencies": {
    "vitepress": "^1.6.4",
    "vitepress-plugin-glossary": "^1.0.6",
    "vitest": "^4.1.1"
  },
  "engines": {
    "node": ">=23.6.0"
  }
}
