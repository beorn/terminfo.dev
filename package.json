    "loggily": "^0.4.0",
    "silvery": "^0.4.1"
  },
  "devDependencies": {
    "@bearly/vitepress-enrich": "^0.3.0",
    "vitepress": "^1.6.4",
    "vitest": "^4.1.1"
  },
